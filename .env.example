# Copy to .env or .env.local and fill in values.
# Used for local dev and production (e.g. on VPS).

# Local dev: PORT=3000. On VPS with Nginx on 8060: backend runs internal PORT=3000.
PORT=3000
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------------------------------------------------------
# CORS (frontend origins allowed to call backend)
# ---------------------------------------------------------------------------
# Prefer CORS_ORIGINS for multiple frontends (comma-separated, no trailing slash).
# Railway + Vercel example:
# CORS_ORIGINS=https://your-admin.vercel.app,https://your-restaurant.vercel.app,https://your-customer.vercel.app
#
# Local dev example:
# CORS_ORIGINS=http://localhost:5173,http://localhost:5174
#
# Optional single-origin form:
# CORS_ORIGIN=https://your-admin.vercel.app

# Optional: Stripe (for payments)
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: Supabase timeout (ms)
# SUPABASE_FETCH_TIMEOUT_MS=10000

# ---------------------------------------------------------------------------
# File upload (restaurant images): Cloudflare R2 or Supabase Storage
# ---------------------------------------------------------------------------
# Supabase Storage is the default provider.
# UPLOAD_PROVIDER=supabase
# Optional: Supabase bucket for restaurant images
# SUPABASE_STORAGE_BUCKET=kolia-images

# Set UPLOAD_PROVIDER=r2 to use R2 instead.
# UPLOAD_PROVIDER=r2

# Base URL where uploaded files are publicly accessible (required when UPLOAD_PROVIDER=r2).
# For R2: use your R2 public bucket URL, e.g. https://pub-xxx.r2.dev or https://images.yourdomain.com
# FILE_UPLOAD_PUBLIC_URL=https://your-r2-public-url.r2.dev

# Cloudflare R2 (S3-compatible) — required when UPLOAD_PROVIDER=r2
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_BUCKET_NAME=kolia-images
